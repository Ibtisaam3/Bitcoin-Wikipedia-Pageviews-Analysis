project = "en.wikipedia.org",
access = "all-access",
agents = "all-agents",
granularity = "daily",
start = "20150701",
end = format(Sys.Date(), "%Y%m%d")) {
# URL-encode the article title for the API
article_encoded <- utils::URLencode(article, reserved = TRUE)
# Build endpoint URL
url <- paste0(
"https://wikimedia.org/api/rest_v1/metrics/pageviews/per-article/",
project, "/", access, "/", agents, "/", article_encoded, "/",
granularity, "/", start, "/", end
)
# Wikimedia asks for a User-Agent header
con <- url(url, headers = c(
"User-Agent" = "MTH6139-Time-Series-Coursework/1.0 (student project)"
))
# Read JSON
raw_json <- readLines(con, warn = FALSE)
close(con)
data <- fromJSON(paste(raw_json, collapse = ""))
# Extract items
items <- data$items
# Convert to dataframe
df <- data.frame(
ds = as.Date(substr(items$timestamp, 1, 8), format = "%Y%m%d"),
y = items$views
)
return(df)
}
# Download Bitcoin pageviews
bitcoin_pageviews <- get_wiki_pageviews()
# Check the first few rows
head(bitcoin_pageviews)
# Save to CSV
write.csv(bitcoin_pageviews, "bitcoin_wikipedia_pageviews.csv", row.names = FALSE)
